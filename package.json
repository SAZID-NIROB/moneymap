{
  "name": "expense-tracker-mern",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "server": "npm run dev --workspace server",
    "client": "npm run dev --workspace client",
    "build": "npm run build --workspace client",
    "build:all": "npm run build --workspace client && npm install --workspace server",
    "install:all": "npm install --workspaces",
    "test:build": "npm run build --workspace client",
    "preview:client": "npm run preview --workspace client"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
